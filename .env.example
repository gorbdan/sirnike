BOT_TOKEN=
IMGBB_API_KEY=
PROVIDER_TOKEN=

# Pick one provider: YESAPI, MASHAGPT, or ZVENO.
AI_PROVIDER=YESAPI

# YESAPI / Nano Banana
NANO_API_BASE=https://api.yesai.su/v2/google/nanobanana
NANO_API_KEY=

# MashaGPT
MASHAGPT_API_BASE=https://api.mashagpt.ru
MASHAGPT_API_KEY=
MASHAGPT_IMAGE_MODEL=nano-banana-pro
MASHAGPT_CHAT_MODEL=gpt-4o-mini

# ZvenoAI
ZVENO_API_BASE=https://api.zveno.ai/v1
ZVENO_API_KEY=
ZVENO_IMAGE_MODEL=google/gemini-3-pro-image-preview
ZVENO_CHAT_MODEL=google/gemini-2.5-flash

PROMPT_WEBAPP_URL=

# BotHost sets this in the generated Dockerfile. Keep it for local Docker runs too.
DATA_DIR=/app/data
BOT_LOG_DIR=/app/data

KLING_API_BASE=https://api.yesai.su/v2/yesvideo
KLING_VERSION=1.6
KLING_DURATION=10
KLING_DIMENSIONS=16:9
KLING_VIDEO_COST=5
KLING_MAX_POLL_ATTEMPTS=80
KLING_POLL_INTERVAL=15

KLING_MOTION_ENDPOINT=/v1/tasks/kling-2-6-motion-control
KLING_MOTION_VERSION=2.6-pro
KLING_MOTION_COST=5
KLING_MOTION_MODE=720p
KLING_MOTION_ORIENTATION=video
KLING_MOTION_DURATION=10
KLING_MOTION_MAX_POLL_ATTEMPTS=80
KLING_MOTION_POLL_INTERVAL=15
MOTION_CONTROL_ENABLED=0

SEEDANCE_ENABLED=1
SEEDANCE_ENDPOINT=/v1/videos
SEEDANCE_MODEL=bytedance/seedance-2.0
SEEDANCE_COST=5
SEEDANCE_MODE=720p
SEEDANCE_DURATION=5
SEEDANCE_DURATION_OPTIONS=5,10,15
SEEDANCE_COST_PER_SECOND=2.45
SEEDANCE_MAX_POLL_ATTEMPTS=80
SEEDANCE_POLL_INTERVAL=15

SEEDANCE_FAST_ENABLED=1
SEEDANCE_FAST_ENDPOINT=/v1/videos
SEEDANCE_FAST_MODEL=bytedance/seedance-2.0-fast
SEEDANCE_FAST_MODE=720p
SEEDANCE_FAST_DURATION_OPTIONS=5,10
SEEDANCE_FAST_COST_PER_SECOND=1.95

START_BONUS=5
REFERRAL_BONUS_REFERRER=10
REFERRAL_BONUS_NEW_USER=5
FREE_GENERATIONS_PER_DAY=1
BASE_GENERATION_COST=5
REFERENCE_COST=0
MAX_POLL_ATTEMPTS=30
POLL_INTERVAL=60
ADMIN_IDS=320423776
